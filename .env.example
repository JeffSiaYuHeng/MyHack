# Verrier Local Development Environment Variables
# This file is a reference for local development only.
# Duplicate this file to .env.local and replace placeholders with real values.

# AI Configuration
# Get your API key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your-value-here

# Firebase Configuration (Client-Side)
# These values are available in your Firebase Project Settings -> General -> Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=your-value-here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-value-here
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-value-here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-value-here
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-value-here
NEXT_PUBLIC_FIREBASE_APP_ID=your-value-here

# Note: Cloud Run runtime values must be set as GitHub Actions secrets 
# with names matching the environment variable names exactly.
